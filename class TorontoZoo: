class TorontoZoo:
    def __init__(self, pavilion_name, animal, count, habitat, food):
        self.__pavilion_name = pavilion_name
        self.__animal = animal
        self.__count = count
        self.__habitat = habitat
        self.__food = food

    def show_info(self):
        print("Pavilion:", self.__pavilion_name)
        print("Animal:", self.__animal)
        print("Number of Animals:", self.__count)
        print("Habitat:", self.__habitat)
        print("Food:", self.__food)
        print()


# creating zoo pavilion objects
african_pavilion = TorontoZoo("African Pavilion", "Lion", 4, "Savannah", "Meat")
australian_pavilion = TorontoZoo("Australian Pavilion", "Kangaroo", 6, "Grassland", "Plants")
south_american_pavilion = TorontoZoo("South American Pavilion", "Monkey", 8, "Rainforest", "Fruits")

# displaying information
african_pavilion.show_info()
australian_pavilion.show_info()
south_american_pavilion.show_info()



